{
  "name": "stellar-stream-processor",
  "version": "1.0.0",
  "description": "Stream processing worker for Stellar Streaming",
  "main": "dist/worker.js",
  "scripts": {
    "start": "node dist/worker.js",
    "dev": "ts-node src/worker.ts",
    "build": "tsc",
    "test": "jest",
    "test:cov": "jest --coverage",
    "lint": "eslint --config ../eslint.config.js src __tests__"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "forceExit": true,
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "nock": "^13.3.0"
  }
}
