# ──────────────────────────────────────────────────────────────────────────────
# xstreamroll-processing/ — Stream-processing worker environment
#
# Copy this file to `.env` and adjust the values for your local setup:
#   cp xstreamroll-processing/.env.example xstreamroll-processing/.env
#
# Running the stack with `docker compose up` from the repo root instead?
# You don't need this file at all — docker-compose.yml already sets these
# variables for you, using the `api`/`postgres` service hostnames.
#
# The worker polls the API over HTTP for pending events and posts processed
# results back — it does not connect to the database or a message broker
# directly. All values below are safe for local development only.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the API service the worker pulls events from and posts results to.
# Must be a valid URL. Defaults to http://localhost:3001 when unset.
# Running via Docker Compose: use the `api` service hostname instead of
# `localhost`, e.g. http://api:3001
API_URL=http://localhost:3001

# Runtime mode: development | production | test
NODE_ENV=development

# How often (in milliseconds) the worker polls the API for pending events.
POLL_INTERVAL_MS=5000

# Maximum number of stream sessions processed concurrently. Defaults to 32.
MAX_CONCURRENT_SESSIONS=32

# ──────────────────────────────────────────────────────────────────────────────
# Distributed session coordination (issue #216)
#
# When horizontally scaling the worker, two pods polling the API in parallel
# would otherwise register sessions for the same streamId and double-publish
# every event. The worker guards against this with a small distributed lock
# layer. Two backends are supported:
#
#   memory   — per-process Map. Appropriate for tests and single-worker
#              deployments. Default.
#   postgres — fronts a `stream_locks` table in PostgreSQL. Use this when
#              you run >1 worker replica. Requires DATABASE_URL.
# ──────────────────────────────────────────────────────────────────────────────

LOCK_BACKEND=memory

# Postgres connection string used when LOCK_BACKEND=postgres. Must be a
# libpq-style URL, e.g. postgres://user:pass@host:5432/dbname. Ignored
# when LOCK_BACKEND=memory.
# Running via Docker Compose: use the `postgres` service hostname instead
# of `localhost`, e.g. postgres://postgres:postgres@postgres:5432/xstreamroll_dev
DATABASE_URL=postgres://xstreamroll:xstreamroll@localhost:5432/xstreamroll

# Time-to-live, in milliseconds, for an acquired stream lock. The worker
# heartbeats at TTL/3 so two consecutive renew extensions always fit.
LOCK_TTL_MS=30000

# ──────────────────────────────────────────────────────────────────────────────
# Distributed event-filter config store (issue #351)
#
# The EventFilter decides which stream events to drop before they
# reach a session. Pre-#351 the configs only existed inside the
# running worker, so a setConfig call on worker A did nothing for
# worker B — filtered events slipped through on peer pods. The
# store abstracts persistence + propagation; two backends ship:
#
#   memory — per-process Map. Default. Fine for tests and any
#            single-worker deployment. Same semantics as pre-#351.
#   redis  — fronts a Redis hash + pub/sub channel so every worker
#            in the cluster agrees on which streams to filter. Use
#            this in any horizontally-scaled deployment.
# ──────────────────────────────────────────────────────────────────────────────

EVENT_FILTER_BACKEND=memory

# Redis URL used when EVENT_FILTER_BACKEND=redis. Falls back to
# REDIS_URL when unset so a worker that already shares the API's
# Redis can reuse the connection (most production deployments).
# Running via Docker Compose: redis://redis:6379
# Running in k8s:              redis://redis.xstreamroll.svc.cluster.local:6379
# Ignored when EVENT_FILTER_BACKEND=memory.
EVENT_FILTER_REDIS_URL=

# ──────────────────────────────────────────────────────────────────────────────
# Distributed tracing (issue #346)
#
# The worker attaches a W3C traceparent header to every outbound request so
# the API can correlate worker poll cycles and callbacks to a single trace.
# No OTEL SDK is required in the worker — context is propagated via the
# standard traceparent header using randomly generated trace IDs.
#
# If you run a trace collector (Jaeger, Tempo, OTel Collector), set the
# same OTEL_EXPORTER_OTLP_ENDPOINT in the API service's environment so
# the API can export spans linked to the worker's traceparents.
# ──────────────────────────────────────────────────────────────────────────────

# Optional: label emitted in logs alongside the traceparent for quick
# correlation without a collector.
OTEL_SERVICE_NAME=xstreamroll-processing
