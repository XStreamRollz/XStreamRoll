{
  "name": "@stellar/streaming-sdk",
  "version": "1.0.0",
  "description": "Stellar Streaming SDK for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "coverageDirectory": "coverage",
    "coverageReporters": ["lcov", "text"]
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.0"
  }
}
