{
  "name": "@stellar/streaming-sdk",
  "version": "1.0.0",
  "description": "Stellar Streaming SDK for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:cov": "jest --coverage",
    "generate:types": "./scripts/generate-types.sh"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transformIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcov",
      "text"
    ]
  },
  "dependencies": {
    "@xstreamroll/types": "file:../packages/types"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@xstreamroll/contract-tests": "file:../tests/contracts",
    "jest": "^29.7.0",
    "nock": "^14.0.15",
    "openapi-typescript": "^7.13.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.0"
  }
}
