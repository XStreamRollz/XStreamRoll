{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "mutate": [
    "src/auth/**/*.ts",
    "src/common/guards/**/*.ts"
  ],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "package.json",
    "enableFindRelatedTests": true
  },
  "reporters": [
    "html",
    "json",
    "progress",
    "clear-text"
  ],
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "coverageAnalysis": "perTest",
  "concurrency": 2,
  "timeoutMS": 30000,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true,
  "buildCommand": "npx tsc --noEmit",
  "excludedMutations": [
    "StringLiteral"
  ]
}
