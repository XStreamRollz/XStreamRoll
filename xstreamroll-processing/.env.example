# ──────────────────────────────────────────────────────────────────────────────
# xstreamroll-processing/ — Stream-processing worker environment
#
# Copy this file to `.env` and adjust the values for your local setup:
#   cp xstreamroll-processing/.env.example xstreamroll-processing/.env
#
# The worker polls the API over HTTP for pending events and posts processed
# results back — it does not connect to the database or a message broker
# directly. All values below are safe for local development only.
# ──────────────────────────────────────────────────────────────────────────────

# Base URL of the API service the worker pulls events from and posts results to.
# Must be a valid URL. Defaults to http://localhost:3001 when unset.
API_URL=http://localhost:3001

# Runtime mode: development | production | test
NODE_ENV=development

# How often (in milliseconds) the worker polls the API for pending events.
POLL_INTERVAL_MS=5000

# Maximum number of stream sessions processed concurrently. Defaults to 32.
MAX_CONCURRENT_SESSIONS=32

# ──────────────────────────────────────────────────────────────────────────────
# Distributed session coordination (issue #216)
#
# When horizontally scaling the worker, two pods polling the API in parallel
# would otherwise register sessions for the same streamId and double-publish
# every event. The worker guards against this with a small distributed lock
# layer. Two backends are supported:
#
#   memory   — per-process Map. Appropriate for tests and single-worker
#              deployments. Default.
#   postgres — fronts a `stream_locks` table in PostgreSQL. Use this when
#              you run >1 worker replica. Requires DATABASE_URL.
# ──────────────────────────────────────────────────────────────────────────────

LOCK_BACKEND=memory

# Postgres connection string used when LOCK_BACKEND=postgres. Must be a
# libpq-style URL, e.g. postgres://user:pass@host:5432/dbname. Ignored
# when LOCK_BACKEND=memory.
DATABASE_URL=postgres://xstreamroll:xstreamroll@localhost:5432/xstreamroll

# Time-to-live, in milliseconds, for an acquired stream lock. The worker
# heartbeats at TTL/3 so two consecutive renew extensions always fit.
LOCK_TTL_MS=30000
